---
const posts = Object.values(import.meta.glob('./blog/*.md', { eager: true }));
---
<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <title>Personal Blog</title>
    <style>
      body { background-color: #c0c0c0; color: #000000; font-family: "Times New Roman", Times, serif; margin: 20px; }
      .container { background-color: #ffffff; border: 3px double #000000; padding: 20px; max-width: 800px; margin: 0 auto; }
      h1 { color: #000080; text-align: center; border-bottom: 2px solid #000000; padding-bottom: 10px; }
      a { color: #0000ff; text-decoration: underline; }
      .menu { text-align: center; margin-bottom: 20px; font-weight: bold; }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>HUNG'S PERSONAL DIARY</h1>
      <div class="menu">
        [ <a href="/">About Me</a> ] [ <a href="/research">Research & Papers</a> ] [ <a href="/studies">Studies & Notes</a> ] [ <a href="/blog">Personal Blog</a> ]
      </div>
      <h3>THOUGHTS & STORIES:</h3>
      <ul>
        {posts.map((post: any) => (
          <li style="margin-bottom: 15px; list-style-type: square;">
            <a href={post.url}>{post.frontmatter.title}</a> — <span style="color:#555; font-size:0.9em;">{post.frontmatter.date}</span>
            <p style="margin: 5px 0 0 0; font-size: 0.95em;">{post.frontmatter.description}</p>
          </li>
        ))}
      </ul>
    </div>
  </body>
</html>