---
// Đọc tất cả các file markdown bài viết trong thư mục src/content/blog/
const posts = Object.values(import.meta.glob('./blog/*.md', { eager: true }));
---

<html lang="vi">
  <head>
    <meta charset="utf-8" />
    <title>advanture w/ Hunhlm</title>
    <style>
      /* CSS thô sơ theo tiêu chuẩn năm 1999 */
      body {
        background-color: #c0c0c0; /* Màu nền xám kinh điển của Windows 95 */
        color: #000000;
        font-family: "Times New Roman", Times, serif;
        margin: 20px;
      }
      .container {
        background-color: #ffffff;
        border: 3px double #000000; /* Viền đôi thô kinh điển */
        padding: 20px;
        max-width: 800px;
        margin: 0 auto;
      }
      h1 {
        color: #000080; /* Màu xanh nước biển đậm của thanh tiêu đề Windows */
        text-align: center;
        border-bottom: 2px solid #000000;
        padding-bottom: 10px;
      }
      a {
        color: #0000ff;
        text-decoration: underline;
      }
      a:visited {
        color: #800080;
      }
      .menu {
        text-align: center;
        margin-bottom: 20px;
        font-weight: bold;
      }
      .post-item {
        margin-bottom: 15px;
        list-style-type: square; /* Dấu chấm đầu dòng hình vuông cổ điển */
      }
      .date {
        color: #555555;
        font-size: 0.9em;
        font-style: italic;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>advanture w/ Hunhlm</h1>
      
      <div class="menu">
        [ <a href="/">Home</a> ] [ <a href="/about">About Me</a> ] [ <a href="https://github.com/lmhunh" target="_blank">GitHub</a> ]
      </div>

      <p>Welcome to my physics database. This server contains technical documents, research notes on thin films, and source code for material analysis.</p>
      
      <hr />

      <h3>AVAILABLE ARTICLES:</h3>
      <ul>
        {posts.map((post) => (
          <li class="post-item">
            <a href={post.url}>{post.frontmatter.title}</a>
            <span class="date"> — {post.frontmatter.date}</span>
            <p style="margin: 5px 0 0 0; font-size: 0.95em;">{post.frontmatter.description}</p>
          </li>
        ))}
      </ul>

      <hr />
      <center>
        <p><font size="2">Best viewed in Netscape Navigator 4.0 or Internet Explorer 5.0 with 800x600 resolution.</font></p>
      </center>
    </div>
  </body>
</html>